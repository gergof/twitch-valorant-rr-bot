{
  "name": "twitch-valorant-rr-bot",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Twitch bot to output your RR change to the chat at the end of each match",
  "main": "src/index.js",
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "start": "npm run build && node dist/index.js",
    "build": "rimraf dist && tsc && recursive-copy -w src/routes/views dist/routes/views && recursive-copy -w src/static dist/static",
    "typecheck": "tsc --noEmit",
    "lint": "esw --color --ext .ts src",
    "lint:fix": "esw --color --fix --ext .ts src",
    "lint:watch": "esw --color --fix --watch --cache --ext .ts src",
    "release": "commit-and-tag-version"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/gergof/twitch-valorant-rr-bot.git"
  },
  "author": "",
  "license": "GPL-3.0",
  "bugs": {
    "url": "https://github.com/gergof/twitch-valorant-rr-bot/issues"
  },
  "homepage": "https://github.com/gergof/twitch-valorant-rr-bot#readme",
  "dependencies": {
    "@fastify/cookie": "^11.0.2",
    "@fastify/formbody": "^8.0.2",
    "@fastify/session": "^11.1.1",
    "@fastify/static": "^9.0.0",
    "@fastify/view": "^11.1.1",
    "@mikro-orm/core": "^7.0.6",
    "@mikro-orm/migrations": "^7.0.6",
    "@mikro-orm/postgresql": "^7.0.6",
    "@oxc-node/core": "^0.0.35",
    "@sinclair/typebox": "^0.34.48",
    "@twurple/api": "^8.0.3",
    "@twurple/auth": "^8.0.3",
    "@twurple/eventsub-ws": "^8.0.3",
    "connect-redis": "^9.0.0",
    "date-fns": "^4.1.0",
    "dotenv": "^17.3.1",
    "ejs": "^5.0.1",
    "env-var": "^7.5.0",
    "fastify": "^5.8.4",
    "got": "^14.6.6",
    "http-errors": "^2.0.1",
    "nanoid": "^5.1.7",
    "p-limit": "^7.3.0",
    "redis": "^5.11.0",
    "toad-scheduler": "^3.1.0",
    "winston": "^3.19.0"
  },
  "devDependencies": {
    "@mikro-orm/cli": "^7.0.7",
    "@types/ejs": "^3.1.5",
    "@types/http-errors": "^2.0.5",
    "@types/node": "^25.5.0",
    "@typescript-eslint/eslint-plugin": "^8.57.2",
    "@typescript-eslint/parser": "^8.57.2",
    "commit-and-tag-version": "^12.7.1",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-watch": "^8.0.0",
    "prettier": "^3.8.1",
    "recursive-copy-cli": "^1.0.20",
    "rimraf": "^6.1.3",
    "typescript": "^5.9.3"
  },
  "commit-and-tag-version": {
    "scripts": {
      "prerelease": "git fetch --all --tags"
    },
    "types": [
      {
        "type": "feat",
        "section": "Features"
      },
      {
        "type": "fix",
        "section": "Bug Fixes"
      },
      {
        "type": "imp",
        "section": "Improvements"
      },
      {
        "type": "ci",
        "section": "Build/CI"
      },
      {
        "type": "chore",
        "hidden": true
      },
      {
        "type": "docs",
        "section": "Documentation"
      },
      {
        "type": "refactor",
        "section": "Refactor"
      },
      {
        "type": "test",
        "section": "Testing"
      },
      {
        "type": "perf",
        "section": "Performance"
      },
      {
        "type": "intern",
        "section": "Internal"
      }
    ]
  }
}
